---
---

<section id='inicio' class="
	p-10 
	flex
	flex-col
	lg:flex-row
	gap-10

	bg-[var(--bg)] text-center lg:text-start

	lg:p-15 
	">
	<div class="flex-1 flex flex-col items-center lg:items-start gap-4">
		<h1 class="text-2xl lg:text-4xl font-medium">Creo páginas web para negocios que quieren más clientes</h1>
		<p class="text-lg lg:text-2xl text-[var(--text)]">Sitios web y apps móviles simples, rápidos y efectivos</p>
		<a href="https://wa.me/5493512377435" target="_blank" class="hover:bg-[#111] py-4 px-6 text-white font-medium w-fit bg-[#010101ff]">Hablemos de tu proyecto</a>
		<ul class="flex flex-wrap lg:flex-nowrap justify-center lg:justify-start gap-2">
			{["Adaptadas a celulares ·", "SEO para Google ·", "100% personalizadas"].map(a => (
				<li class="font-medium text-[.95rem] truncate">{a}</li>
			))}
		</ul>
	</div>
	<div class="flex-1 flex items-center">
		<img 
			src="/hero-02.png" 
			alt="Ilustración de un sitio web simple y personalizado con su version móvile" 
			class="w-full"
			loading="eager"
			fetchPriority="high"
		/>
	</div>
</section>
